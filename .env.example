# ── OpenRouter (chat AI) ──────────────────────────────────────────────────
# Lấy key tại: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_key_here

# ── FPT.AI TTS (đọc thơ tiếng Việt, miễn phí 30k ký tự/ngày) ────────────
# Đăng ký tại: https://console.fpt.ai → Speech → Text to Speech → Tạo API Key
# Không có key vẫn chạy được (fallback sang Web Speech API)
VITE_FPT_API_KEY=your_fpt_api_key_here
